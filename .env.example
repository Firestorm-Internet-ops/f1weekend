# ============================================
# LOCAL DEVELOPMENT CONFIG
# ============================================

# Database (local MySQL 8.4.6)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=YOUR_PASSWORD_HERE
DATABASE_NAME=pitlane

# Redis (local)
REDIS_URL=redis://localhost:6379

# LLM Provider — switch between 'ollama' and 'anthropic'
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama

# Anthropic (production — uncomment and set when deploying)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Vector DB (Qdrant)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=  (not needed for local)

# Affiliates
GYG_PARTNER_ID=PLACEHOLDER
GYG_API_KEY=GYGP-your-api-key-here

# Google Maps
GOOGLE_MAPS_API_KEY=PLACEHOLDER
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Analytics (client-side, prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Active Race Override — pin the site to a specific race slug.
# Normally DB-driven (auto-switches by race_date). To override:
#   1. Uncomment the line below and set the desired slug
#   2. In src/lib/activeRace.ts, uncomment the two "if (process.env.ACTIVE_RACE_SLUG)" lines
# ACTIVE_RACE_SLUG=japan-2026
```
